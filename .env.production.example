# ─────────────────────────────────────────────────────────────
# DialN — Production Environment Template
# Copy to .env and fill every value marked <CHANGE_ME>
# ─────────────────────────────────────────────────────────────

APP_NAME=DialN
APP_ENV=production
APP_KEY=<CHANGE_ME>            # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://dialn.vedpragya.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

APP_TIMEZONE=UTC
APP_LOGO=logo.png
APP_FAVICON=favicon.png

# ─── Logging ──────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database (Docker service name) ───────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=<CHANGE_ME>        # e.g. dialn_production
DB_USERNAME=<CHANGE_ME>        # e.g. dialn
DB_PASSWORD=<CHANGE_ME>        # strong random password
DB_ROOT_PASSWORD=<CHANGE_ME>   # MySQL root password (used by healthcheck)

# ─── Cache / Session / Queue (all Redis) ──────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.dialn.vedpragya.com

CACHE_STORE=redis

QUEUE_CONNECTION=redis

FILESYSTEM_DISK=local

# ─── Reverb WebSocket ─────────────────────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=<CHANGE_ME>
REVERB_APP_KEY=<CHANGE_ME>
REVERB_APP_SECRET=<CHANGE_ME>
REVERB_HOST=dialn.vedpragya.com
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=<CHANGE_ME>
MAIL_PORT=587
MAIL_USERNAME=<CHANGE_ME>
MAIL_PASSWORD=<CHANGE_ME>
MAIL_FROM_ADDRESS=noreply@dialn.vedpragya.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=<CHANGE_ME>
TWILIO_AUTH_TOKEN=<CHANGE_ME>
TWILIO_PHONE_NUMBER=<CHANGE_ME>        # e.g. +14155551234
TWILIO_WEBHOOK_URL=https://dialn.vedpragya.com

# ─── AI Services ──────────────────────────────────────────────
DEEPGRAM_API_KEY=<CHANGE_ME>
OPENROUTER_API_KEY=<CHANGE_ME>

AI_WEBSOCKET_URL=wss://dialn.vedpragya.com/ws
AI_AUTO_CONFIGURE_TWILIO=true

# ─── Sentry (optional) ────────────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

VITE_SENTRY_DSN="${SENTRY_LARAVEL_DSN}"
VITE_SENTRY_ENVIRONMENT="${APP_ENV}"
VITE_SENTRY_TRACES_SAMPLE_RATE="${SENTRY_TRACES_SAMPLE_RATE}"
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.05
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# ─── Stripe (optional) ────────────────────────────────────────
STRIPE_PUBLIC_KEY=<CHANGE_ME>
STRIPE_SECRET_KEY=<CHANGE_ME>

# ─── Sentry build args (injected at docker build time) ────────
# These are passed as --build-arg to docker compose build, not read at runtime
# SENTRY_ORG=<your-sentry-org>
# SENTRY_PROJECT=<your-sentry-project>
# SENTRY_AUTH_TOKEN=<your-sentry-auth-token>

# ─── Vite (baked into assets at build time — set before build) ─
VITE_APP_NAME="${APP_NAME}"
