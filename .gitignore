# =============================================================================
# Laravel
# =============================================================================
/vendor/
/node_modules/
/.phpunit.cache
/public/hot
/public/build
/public/widget/build
/public/storage
/storage/*.key
/storage/logs/*.log
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/app/public/*
/bootstrap/ssr/
/bootstrap/cache/*.php

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.*
!.env.example
!.env.production.example

# =============================================================================
# Node / Vite build artifacts
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# =============================================================================
# PHP / Composer
# =============================================================================
composer.phar
/.phpunit.result.cache
/phpunit.xml.bak
/auth.json

# =============================================================================
# IDE / Editor
# =============================================================================
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.project
.buildpath
.settings/
nbproject/

# =============================================================================
# OS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Logs & Temp
# =============================================================================
*.log
*.cache
*.tmp
*.swp
*.swo
*~

# =============================================================================
# Docker secrets (keep docker-compose.yml but ignore overrides with secrets)
# =============================================================================
docker-compose.override.yml
docker-compose.*.local.yml

# =============================================================================
# PM2
# =============================================================================
.pm2/
logs/

# =============================================================================
# Sentry / Source maps (generated at build time)
# =============================================================================
.sentryclirc

# =============================================================================
# API docs (generated)
# =============================================================================
/storage/api-docs/

# =============================================================================
# Test artifacts
# =============================================================================
/coverage/
/.phpunit.cache/

# =============================================================================
# Deployment scripts with potential secrets
# =============================================================================
deploy.local.sh
deploy.*.sh
!deploy.sh
